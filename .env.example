# Copy to .env and fill in the values.

# Telegram bot token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# Chat ID where the bot posts notifications (negative for groups)
BOT_CHAT_ID=-4832215610

# Optional channel to mirror notifications
BOT_CHANNEL=@your_channel

# TON → USDT conversion rate (used for profit reporting)
CONVERT_USDT=1.8

# Set to true to skip Portals price cross-check
SKIP_PORTALS=false

# Portal-market auth token (needed if SKIP_PORTALS=false)
AUTH_PORTALS=tma user=...

# Trading parameters (override defaults)
PROFIT_PERCENT=0.15
PROFIT_PERCENT_OFFER=0.10
MIN_PRICE_TON=1.0
MAX_PRICE_TON=2000.0
MAX_PRICE_OFFER_TON=500.0
MAX_COLLECTION_STOCK=3
OFFER_EXPIRE_MINUTES=3
TIME_SLEEP=60

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/mrkt.log

# Path to accounts YAML (default: accounts.yaml next to .env)
ACCOUNTS_FILE=accounts.yaml
