# Rename to accounts.yaml and fill in your tokens.
# Each account needs an auth_token from tgmrkt.io.
#
# Available roles:
#   SCANNER  – read-only: feed, collections, listings, orders/top
#   ORDERER  – create / cancel buy orders
#   OFFERER  – create / cancel offers
#   BUYER    – instant buy_gift unstablea
#   SELLER   – put gifts on sale
#   WALLET   – balance, history, activities
#
# Minimal (single account):
accounts:
  - name: main
    auth_token: "YOUR_AUTH_TOKEN_HERE"
    roles:
      - SCANNER
      - ORDERER
      - OFFERER
      - BUYER
      - SELLER
      - WALLET
    rate_limit_rps: 2.0

